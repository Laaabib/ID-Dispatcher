{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, either an admin or a regular employee.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Application": {
      "title": "Application",
      "description": "An ID card and nametag application.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who submitted the application."
        },
        "name": {
          "type": "string",
          "description": "Applicant's name."
        },
        "designation": {
          "type": "string",
          "description": "Applicant's designation."
        },
        "department": {
          "type": "string",
          "description": "Applicant's department."
        },
        "applicationDate": {
          "type": "string",
          "description": "Date of application."
        },
        "joiningDate": {
          "type": "string",
          "description": "Date of joining."
        },
        "nidNumber": {
          "type": "string",
          "description": "National ID number."
        },
        "employeeId": {
          "type": "string",
          "description": "Employee ID."
        },
        "bloodGroup": {
          "type": "string",
          "description": "Applicant's blood group."
        },
        "signatureData": {
          "type": "string",
          "description": "Base64 encoded signature image."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Printed", "Distributed", "Rejected"],
          "description": "Status of the application."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the application was submitted."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the application was last updated."
        }
      },
      "required": ["userId", "name", "designation", "department", "applicationDate", "joiningDate", "nidNumber", "employeeId", "bloodGroup", "signatureData", "status", "createdAt", "updatedAt"]
    },
    "Nametag": {
      "title": "Nametag",
      "description": "A nametag request.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who submitted the request."
        },
        "name": {
          "type": "string",
          "description": "Name to appear on the nametag."
        },
        "designation": {
          "type": "string",
          "description": "Applicant's designation."
        },
        "department": {
          "type": "string",
          "description": "Applicant's department."
        },
        "employeeId": {
          "type": "string",
          "description": "Employee ID."
        },
        "fastenerType": {
          "type": "string",
          "enum": ["Pin", "Magnet"],
          "description": "Type of fastener for the nametag."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Printed", "Distributed", "Rejected"],
          "description": "Status of the request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was submitted."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was last updated."
        }
      },
      "required": ["userId", "name", "designation", "department", "employeeId", "fastenerType", "status", "createdAt", "updatedAt"]
    },
    "DailyWork": {
      "title": "DailyWork",
      "description": "A daily work task.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the task."
        },
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "description": {
          "type": "string",
          "description": "Optional description of the task."
        },
        "taskTime": {
          "type": "string",
          "description": "Time of the task."
        },
        "taskDate": {
          "type": "string",
          "description": "Date of the task."
        },
        "reason": {
          "type": "string",
          "description": "Reason for the task."
        },
        "timesNeeded": {
          "type": "string",
          "description": "Times needed to finish the task."
        },
        "remarks": {
          "type": "string",
          "description": "Additional remarks."
        },
        "status": {
          "type": "string",
          "enum": ["queued", "pending", "done"],
          "description": "Status of the task."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was last updated."
        }
      },
      "required": ["userId", "title", "status", "createdAt", "updatedAt"]
    },
    "ItemInventory": {
      "title": "ItemInventory",
      "description": "Item inventory records.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "quantity", "createdAt", "updatedAt"]
    },
    "AssetInventory": {
      "title": "AssetInventory",
      "description": "Asset inventory records.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "serialNumber": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "createdAt", "updatedAt"]
    },
    "ToolInventory": {
      "title": "ToolInventory",
      "description": "Tool inventory records.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "assignedTo": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "quantity", "createdAt", "updatedAt"]
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "employeeId": { "type": "string" },
        "department": { "type": "string" },
        "designation": { "type": "string" },
        "joiningDate": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "employeeId", "department", "designation", "status", "createdAt", "updatedAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "A daily attendance record for an employee.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "checkInTime": { "type": "string" },
        "checkOutTime": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Leave", "Half Day"] },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "date", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    },
    "applications/{applicationId}": {
      "schema": {
        "$ref": "#/entities/Application"
      },
      "description": "Stores ID card applications."
    },
    "nametags/{nametagId}": {
      "schema": {
        "$ref": "#/entities/Nametag"
      },
      "description": "Stores nametag requests."
    },
    "daily_works/{workId}": {
      "schema": {
        "$ref": "#/entities/DailyWork"
      },
      "description": "Stores daily work tasks."
    },
    "item_inventory/{itemId}": {
      "schema": {
        "$ref": "#/entities/ItemInventory"
      },
      "description": "Stores item inventory."
    },
    "asset_inventory/{assetId}": {
      "schema": {
        "$ref": "#/entities/AssetInventory"
      },
      "description": "Stores asset inventory."
    },
    "tool_inventory/{toolId}": {
      "schema": {
        "$ref": "#/entities/ToolInventory"
      },
      "description": "Stores tool inventory."
    },
    "employees/{employeeId}": {
      "schema": {
        "$ref": "#/entities/Employee"
      },
      "description": "Stores employee records."
    },
    "attendance/{attendanceId}": {
      "schema": {
        "$ref": "#/entities/Attendance"
      },
      "description": "Stores daily attendance records."
    }
  }
}
